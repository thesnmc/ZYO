# =========================
# 1. RUST & CARGO
# =========================
target/
**/*.rs.bk
# Note: Cargo.lock is typically checked in for binary projects to ensure reproducible builds, 
# but target/ MUST be ignored to prevent pushing compiled Rust artifacts.

# =========================
# 2. C & eBPF ARTIFACTS
# =========================
*.o
*.bpf.o
vmlinux.h
scx/
compile_commands.json
.clangd/

# =========================
# 3. PYTHON & ENVIRONMENTS
# =========================
zyo-env/
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# =========================
# 4. AI MODELS & HEAVY DEPS
# =========================
# Ignore the 2GB C++ engine and its zip files
libtorch/
libtorch-*.zip
*.zip

# Ignore Neural Network weights (Use Git LFS or a download link in README for these)
*.pth
*.pt
*.onnx

# =========================
# 5. SECRETS & LOGS
# =========================
.env
*.log
nohup.out

# =========================
# 6. OS & IDE JUNK
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# 7. TELEMETRY & DATA BANKS (CRITICAL)
# =========================
# Never push your local machine's hardware stats or network logs!
*.csv
zyo_training_data_v3.csv

# =========================
# 8. CRASH DUMPS & PANICS
# =========================
# If the C code segfaults or Rust panics, Linux might dump memory here
core
core.*
*.crash

# =========================
# 9. EDITOR TEMP FILES
# =========================
# Vim/Emacs/Nano background swap files
*.swp
*.swo
*~

# =========================
# 10. LOCAL LLM ARTIFACTS
# =========================
# Just in case you ever download raw model weights directly to the folder
*.gguf